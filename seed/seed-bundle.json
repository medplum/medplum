        "name": "SemaglutideTitration",
        "title": "Semaglutide Titration Protocol",
        "status": "active",
        "type": { "text": "clinical-protocol" },
        "description": "Baseline panel, monthly titrated therapy, and quarterly monitoring for 503A compounded semaglutide. Starter template — review clinically before use.",
        "action": [
          { "title": "Baseline", "description": "Baseline metabolic panel + eligibility review (month 0)", "timingTiming": { "repeat": { "count": 1 } } },
          { "title": "Month 1 — 0.25 mg weekly", "description": "Initiate semaglutide 0.25 mg SC weekly" },
          { "title": "Month 2 — 0.5 mg weekly", "description": "Titrate to 0.5 mg SC weekly if tolerated" },
          { "title": "Month 3 — retest + 1.0 mg", "description": "Quarterly monitoring panel; titrate to 1.0 mg weekly if indicated" },
          { "title": "Quarterly monitoring", "description": "Repeat monitoring panel every 3 months", "timingTiming": { "repeat": { "frequency": 1, "period": 3, "periodUnit": "mo" } } }
        ]
      },
      "request": { "method": "PUT", "url": "PlanDefinition?identifier=https://medsscript.com/protocol|semaglutide-titration" }
    },
