    "@medplum/dosespot-react": "5.1.9",
    "@medplum/scriptsure-react": "5.1.9",
    "@medplum/eslint-config": "5.1.9",
    "@medplum/fhirtypes": "5.1.9",
    "@medplum/health-gorilla-core": "5.1.9",
    "@medplum/health-gorilla-react": "5.1.9",
    "@medplum/react": "5.1.9",
    "@tabler/icons-react": "3.41.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
