    "postcss": "8.5.10",
    "postcss-preset-mantine": "1.18.0",
    "prettier-plugin-organize-imports": "4.3.0",
    "react": "19.2.5",
    "react-big-calendar": "1.19.4",
    "react-dom": "19.2.5",
    "react-live": "4.1.8",
    "react-router": "7.14.2",
    "recharts": "3.8.1",
    "typescript": "6.0.3",
    "vite": "8.0.10",
