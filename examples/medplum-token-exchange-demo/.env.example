# Medplum server base URL.
# Local Medplum server: http://localhost:8103/
# Hosted Medplum:      https://api.medplum.com/
MEDPLUM_BASE_URL=http://localhost:8103/

# The client ID used to select the external auth provider during token exchange.
# - Self-hosted: the `clientId` of a server `externalAuthProviders` entry
#   (or the entry's `identityProvider.clientId` if no top-level `clientId` is set).
# - Hosted:      the ID of a ClientApplication that has an `identityProvider` configured.
MEDPLUM_AUTH_PROVIDER_ID=

# Optional. Target a specific ProjectMembership so the external identity authenticates
# into a project other than the client's own project. Leave empty to use the default.
MEDPLUM_MEMBERSHIP_ID=

# --- External access token ---
# A USER access token from your external IdP (must include scopes so the IdP's userinfo
# endpoint returns an email, e.g. "openid email"). Either paste one here directly, or run
# `npm run token` to perform an interactive login and have it written here automatically.
EXTERNAL_ACCESS_TOKEN=

# --- External IdP login helper (`npm run token`) ---
# Vendor neutral OAuth2 authorization-code login. Works with any IdP (Okta, Auth0,
# Cognito, Entra ID, etc.) - just point these at your provider's endpoints.
# Performs an interactive browser login as a real user and writes the resulting
# access token into EXTERNAL_ACCESS_TOKEN above.
# IDP_REDIRECT_URI must be registered as a redirect/callback URI on the IdP app.
# IDP_CLIENT_SECRET is optional - omit it for public clients (PKCE is always used).
#
# Example endpoints by vendor:
#   Okta:      https://<org>.okta.com/oauth2/v1/authorize  + /oauth2/v1/token
#   Auth0:     https://<tenant>.auth0.com/authorize        + /oauth/token
#   Cognito:   https://<domain>/oauth2/authorize           + /oauth2/token
#   Entra ID:  https://login.microsoftonline.com/<tenant>/oauth2/v2.0/authorize + .../token
IDP_AUTHORIZE_URL=
IDP_TOKEN_URL=
IDP_CLIENT_ID=
IDP_CLIENT_SECRET=
IDP_REDIRECT_URI=http://localhost:8000/callback
IDP_SCOPE=openid email profile
