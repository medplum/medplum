{
  "name": "medplum-document-extraction-bot",
  "version": "5.1.11",
  "description": "Medplum Document Extraction Bot",
  "license": "Apache-2.0",
  "author": "Medplum <hello@medplum.com>",
  "type": "module",
  "scripts": {
    "build": "npm run clean && tsc && node --no-warnings esbuild-script.mjs",
    "clean": "rimraf dist",
    "deploy": "npm run build && npx medplum bot deploy ai-textract",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prettier": "prettier --write .",
    "test": "vitest run src/ai-textract.test.ts",
    "test:e2e": "vitest run src/ai-textract.e2e.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest watch"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "@medplum/bot-layer": "5.1.11",
    "@medplum/cli": "5.1.11",
    "@medplum/core": "5.1.11",
    "@medplum/eslint-config": "5.1.11",
    "@medplum/fhirtypes": "5.1.11",
    "@medplum/mock": "5.1.11",
    "@types/node": "22.19.18",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "esbuild": "0.28.0",
    "fast-glob": "3.3.3",
    "openai": "^4.104.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  }
}
