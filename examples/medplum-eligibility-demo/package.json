{
  "name": "medplum-eligibility-demo",
  "version": "5.1.16",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:bots && tsc && vite build",
    "build:bots": "npm run clean && tsc && node --no-warnings esbuild-script.mjs && tsx src/scripts/deploy-bots.ts",
    "clean": "rimraf dist data/example/example-bots.json",
    "dev": "vite",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "@mantine/core": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@mantine/notifications": "8.3.18",
    "@mantine/spotlight": "8.3.18",
    "@medplum/core": "5.1.16",
    "@medplum/definitions": "5.1.16",
    "@medplum/eslint-config": "5.1.16",
    "@medplum/fhirtypes": "5.1.16",
    "@medplum/mock": "5.1.16",
    "@medplum/react": "5.1.16",
    "@tabler/icons-react": "3.44.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "0.28.0",
    "postcss": "8.5.15",
    "postcss-preset-mantine": "1.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.17.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  }
}
