{
  "name": "@medplum-video/bots",
  "version": "0.1.0",
  "description": "Medplum Video Visit Bots — room provisioning, tokens, lifecycle",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json && node --no-warnings esbuild-script.mjs",
    "clean": "rimraf dist",
    "deploy": "npm run build && tsx src/scripts/deploy.ts local",
    "deploy:staging": "npm run build && tsx src/scripts/deploy.ts staging",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "@medplum/bot-layer": "5.1.8",
    "@medplum/core": "5.1.8",
    "@medplum/eslint-config": "5.1.8",
    "@medplum/fhirtypes": "5.1.8",
    "@medplum/mock": "5.1.8",
    "@types/node": "22.19.17",
    "esbuild": "0.28.0",
    "fast-glob": "3.3.3",
    "livekit-server-sdk": "^2.9.1",
    "@vitest/coverage-v8": "4.1.4",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  }
}
