{
  "name": "@medplum-video/test-harness",
  "version": "0.1.0",
  "description": "Standalone dev/QA test page for medplum-video",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "preview": "vite preview"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "@mantine/core": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@mantine/notifications": "8.3.18",
    "@medplum/core": "5.1.8",
    "@medplum/eslint-config": "5.1.8",
    "@medplum/fhirtypes": "5.1.8",
    "@medplum/react": "5.1.8",
    "@medplum/react-hooks": "5.1.8",
    "@medplum-video/react": "0.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "esbuild": "0.28.0",
    "postcss": "8.5.9",
    "postcss-preset-mantine": "1.18.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.0",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  }
}
