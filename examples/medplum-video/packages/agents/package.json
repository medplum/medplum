{
  "name": "@medplum-video/agents",
  "version": "0.1.0",
  "description": "Medplum Video Visit AI Agents — scribe, intake, coding (LiveKit Agents TS)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "start": "node dist/entrypoint.js start",
    "dev": "tsx src/entrypoint.ts dev",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "dependencies": {
    "@livekit/agents": "^1.0.7",
    "@livekit/agents-plugin-deepgram": "^1.0.7",
    "@livekit/agents-plugin-openai": "^1.0.7",
    "@livekit/agents-plugin-silero": "^1.0.7",
    "@medplum/core": "5.1.8",
    "@medplum/fhirtypes": "5.1.8"
  },
  "devDependencies": {
    "@medplum/eslint-config": "5.1.8",
    "@medplum/mock": "5.1.8",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "4.1.4",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  }
}
