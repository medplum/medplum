{
  "name": "@medplum-video/react",
  "version": "0.1.0",
  "description": "Medplum Video Visit React components — VideoRoom, WaitingRoom, Lobby",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "peerDependencies": {
    "@mantine/core": ">=8.0.0",
    "@medplum/core": ">=5.0.0",
    "@medplum/react": ">=5.0.0",
    "@medplum/react-hooks": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.1.5",
    "@livekit/track-processors": "^0.6.1",
    "@mantine/core": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@medplum/core": "5.1.8",
    "@medplum/eslint-config": "5.1.8",
    "@medplum/fhirtypes": "5.1.8",
    "@medplum/mock": "5.1.8",
    "@medplum/react": "5.1.8",
    "@medplum/react-hooks": "5.1.8",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.4",
    "livekit-client": "^2.13.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  }
}
