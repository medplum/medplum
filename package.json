{
  "name": "root",
  "version": "5.1.21",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=!@medplum/docs --filter=!./examples/*",
    "build:all": "turbo run build",
    "build:docs": "turbo run build --filter=@medplum/docs",
    "build:fast": "turbo run build --filter=@medplum/app --filter=@medplum/server",
    "clean": "turbo run clean",
    "lint": "turbo run lint --filter=!@medplum/docs",
    "lint:fix": "turbo run lint:fix --filter=!@medplum/docs",
    "prettier": "prettier --write \"**/*.{ts,tsx,cts,mts,js,jsx,cjs,mjs,json}\"",
    "sort-package-json": "sort-package-json package.json \"packages/*/package.json\" \"examples/*/package.json\"",
    "test": "turbo run test --filter=!@medplum/docs"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-organize-imports"
    ],
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "overrides": {
    "@jest/types": "30.4.1",
    "esbuild": "0.28.1",
    "jest-diff": "30.4.1",
    "jest-message-util": "30.4.1",
    "jest-util": "30.4.1",
    "jest-worker": "30.4.1",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "whatwg-url": "14.0.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@jest/globals": "30.4.1",
    "@jest/types": "30.4.1",
    "@microsoft/api-documenter": "7.30.7",
    "@microsoft/api-extractor": "7.58.9",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.21",
    "babel-jest": "30.4.1",
    "babel-preset-vite": "1.1.3",
    "cross-env": "10.1.0",
    "esbuild": "0.28.1",
    "formidable": "3.5.4",
    "jest": "30.4.2",
    "jest-diff": "30.4.1",
    "jest-each": "30.4.1",
    "jest-environment-jsdom": "30.4.1",
    "jest-message-util": "30.4.1",
    "jest-util": "30.4.1",
    "jest-worker": "30.4.1",
    "jsdom": "29.1.1",
    "npm-check-updates": "22.2.3",
    "nyc": "18.0.0",
    "prettier": "3.8.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "shx": "0.4.0",
    "sort-package-json": "4.0.0",
    "source-map-explorer": "2.5.3",
    "tslib": "2.8.1",
    "tsx": "4.22.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "vitest-websocket-mock": "0.5.0"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.18.0 <23.0.0 || >=24.2.0 <25.0.0"
  }
}
