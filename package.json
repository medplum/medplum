{
  "name": "root",
  "version": "5.1.26",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=!@medplum/docs --filter=!./examples/*",
    "build:all": "turbo run build",
    "build:docs": "turbo run build --filter=@medplum/docs",
    "build:fast": "turbo run build --filter=@medplum/app --filter=@medplum/server",
    "clean": "turbo run clean",
    "lint": "turbo run lint --filter=!@medplum/docs",
    "lint:fix": "turbo run lint:fix --filter=!@medplum/docs",
    "prettier": "prettier --write \"**/*.{ts,tsx,cts,mts,js,jsx,cjs,mjs,json}\"",
    "sort-package-json": "sort-package-json package.json \"packages/*/package.json\" \"examples/*/package.json\"",
    "test": "turbo run test --filter=!@medplum/docs"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-organize-imports"
    ],
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "typescript": "6.0.3",
    "uuid": "14.0.1",
    "vite": "8.1.5",
    "whatwg-url": "14.0.0"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "7.30.9",
    "@microsoft/api-extractor": "7.58.11",
    "@types/jsdom": "28.0.3",
    "@types/node": "22.20.1",
    "@vitejs/plugin-react": "6.0.3",
    "cross-env": "10.1.0",
    "esbuild": "0.28.1",
    "formidable": "3.5.4",
    "jsdom": "29.1.1",
    "npm-check-updates": "22.2.9",
    "nyc": "18.0.0",
    "prettier": "3.9.5",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "shx": "0.4.0",
    "sort-package-json": "4.0.0",
    "source-map-explorer": "2.5.3",
    "tslib": "2.8.1",
    "tsx": "4.23.1",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "vitest-websocket-mock": "0.5.0"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.18.0 <23.0.0 || >=24.2.0 <25.0.0"
  }
}
