# Medplum Configuration
# Copy this file to .env.local and fill in your values

# Medplum API Base URL
NEXT_PUBLIC_MEDPLUM_BASE_URL=https://api.medplum.com

# Medplum Client ID (from Project > Clients)
NEXT_PUBLIC_MEDPLUM_CLIENT_ID=your-client-id-here

# Optional: Project ID for default project
NEXT_PUBLIC_MEDPLUM_PROJECT_ID=your-project-id-here
