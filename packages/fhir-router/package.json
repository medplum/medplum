{
  "name": "@medplum/fhir-router",
  "version": "5.1.21",
  "description": "Medplum FHIR Router",
  "keywords": [
    "medplum",
    "fhir",
    "healthcare",
    "interoperability",
    "json",
    "serialization",
    "hl7",
    "standards",
    "clinical",
    "dstu2",
    "stu3",
    "r4",
    "normative"
  ],
  "homepage": "https://www.medplum.com/",
  "bugs": {
    "url": "https://github.com/medplum/medplum/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medplum/medplum.git",
    "directory": "packages/fhir-router"
  },
  "license": "Apache-2.0",
  "author": "Medplum <hello@medplum.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./sqlite": {
      "import": {
        "types": "./dist/esm/sqlite.d.ts",
        "default": "./dist/esm/sqlite.mjs"
      },
      "require": {
        "types": "./dist/cjs/sqlite.d.ts",
        "default": "./dist/cjs/sqlite.cjs"
      }
    }
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/cjs/index.d.ts",
  "files": [
    "dist/cjs",
    "dist/esm"
  ],
  "scripts": {
    "api-extractor": "api-extractor run --local && shx cp dist/types.d.ts dist/cjs/index.d.ts && shx cp dist/types.d.ts dist/esm/index.d.ts && shx cp dist/types/sqlite/index.d.ts dist/cjs/sqlite.d.ts && shx cp dist/types/sqlite/index.d.ts dist/esm/sqlite.d.ts",
    "build": "npm run clean && tsc && node esbuild.mjs && npm run api-extractor",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@medplum/core": "5.1.21",
    "@medplum/definitions": "5.1.21",
    "@medplum/fhirtypes": "5.1.21",
    "dataloader": "2.2.3",
    "graphql": "16.14.2",
    "rfc6902": "5.2.0"
  },
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  }
}
