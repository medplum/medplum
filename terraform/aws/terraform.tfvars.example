# terraform.tfvars.example — copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is excluded from version control (.gitignore) to prevent accidental
# commit of real credentials. Never commit your actual terraform.tfvars.

# ── Core ──────────────────────────────────────────────────────────────────────
region             = "us-east-1"
environment        = "dev"
deployment_id      = "1"
availability_zones = ["us-east-1a", "us-east-1b"]

app_domain    = "medplum.example.com"
api_domain    = "api.example.com"
support_email = "support@example.com"

tags = {
  app         = "medplum"
  environment = "dev"
}

# ── Compute (EKS) ─────────────────────────────────────────────────────────────
# eks_node_instance_types = ["t3.large"]  # minimum recommended; use m5.large+ for prod
# eks_node_min_size       = 1
# eks_node_max_size       = 5             # upper bound for Cluster Autoscaler
# eks_node_desired_size   = 2             # initial node count; autoscaler adjusts at runtime
# eks_public_access_cidrs = ["203.0.113.0/32"]  # restrict before production — default is 0.0.0.0/0
#
# IAM principals to grant cluster-admin access via EKS Access Entries.
# The terraform apply principal already has cluster-admin automatically.
# Add operators, CI roles, or teammates who need kubectl access:
# eks_admin_arns = [
#   "arn:aws:iam::123456789012:user/alice",
#   "arn:aws:iam::123456789012:role/ci-deploy-role",
# ]

# ── Database (Aurora PostgreSQL) ──────────────────────────────────────────────
# db_instance_tier = "db.t3.medium"   # use db.r6g.large or larger for production
# rds_instances    = 1                # set to 2 for a writer + reader in production
# postgres_version = "15.4"
#
# rds_ssl_reject_unauthorized controls whether the Medplum server verifies the
# Aurora TLS certificate chain. The server container has no RDS CA bundle, so
# set this to false (dev/test). For production, bundle the RDS CA cert and set true:
#   https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/UsingWithRDS.SSL.html
rds_ssl_reject_unauthorized = false

# ── Cache (ElastiCache Redis) ─────────────────────────────────────────────────
# redis_node_type        = "cache.t3.micro"  # use cache.r6g.large+ for production
# redis_num_cache_nodes  = 1                 # must be >= 2 when environment = "prod"
# redis_multi_az_enabled = true              # set false only for single-node dev clusters

# ── DNS (Route 53) ────────────────────────────────────────────────────────────
# Choose ONE of three modes. Setting both create_route53_zone and
# create_route53_records to true is unsupported and will cause unexpected behavior.
#
#   A) Create the zone (fresh deployment, zone doesn't exist yet):
#        create_route53_zone    = true
#        create_route53_records = false   ← must be false in mode A
#        route53_zone_name      = "example-aws.example.com"
#      If the parent zone (example.com) is also in Route 53 in this account,
#      add its zone ID and Terraform adds the NS delegation record automatically:
#        parent_route53_zone_id = "Z0123456789EXAMPLE"
#      Otherwise, run `terraform output route53_nameservers` after apply and add
#      the four NS records at your registrar or parent DNS provider.
#
#   B) Zone already exists in this account:
#        create_route53_records = true
#        create_route53_zone    = false   ← must be false in mode B
#        route53_zone_name      = "example-aws.example.com"
#
#   C) DNS managed externally — omit all of the above and supply cert ARNs manually (see below).
#
# Uncomment ONE block below:
#
# Mode A — create new hosted zone:
# create_route53_zone    = true
# create_route53_records = false
# route53_zone_name      = "example-aws.example.com"
# parent_route53_zone_id = ""
#
# Mode B — use existing hosted zone:
# create_route53_records = true
# create_route53_zone    = false
# route53_zone_name      = "example-aws.example.com"

# ACM certificates — leave empty to let Terraform request and validate them automatically
# via Route 53 DNS (requires one of modes A or B above). Populate these only when reusing
# existing certificates or when Route 53 is not available (mode C).
# ssl_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT:certificate/APP_CERT_ID"
# alb_certificate_arn = "arn:aws:acm:REGION:ACCOUNT:certificate/ALB_CERT_ID"

# ── Storage CDN (dedicated CloudFront for binary uploads) ─────────────────────
# Enables a dedicated CloudFront distribution for binary storage (presigned URLs).
# Requires an RSA signing key — generate one with:
#   openssl genrsa -aes256 -out cf_signing_key.pem 2048
#   openssl rsa -pubout -in cf_signing_key.pem -out cf_signing_key_pub.pem
# Then upload the public key to CloudFront and paste the returned key ID below.
# See README §3a for full walkthrough.
#
# storage_domain = "storage.example-aws.example.com"
# signing_key_id = "APKA..."
#
# Paste the RSA private key PEM (from cf_signing_key.pem above) as a heredoc:
# signing_key = <<-EOT
#   -----BEGIN RSA PRIVATE KEY-----
#   MIIEowIBAAKCAQEA...
#   -----END RSA PRIVATE KEY-----
# EOT
# signing_key_passphrase = "your-passphrase-here"
#
# Override only to reuse an existing ACM cert (leave empty for automatic validation):
# storage_ssl_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT:certificate/STORAGE_CERT_ID"

# ── WAF ───────────────────────────────────────────────────────────────────────
# enable_waf = true  # default true; set to false to skip WAF (not recommended for production)
# Optional IP allowlists (CLOUDFRONT-scoped sets must be in us-east-1):
# api_waf_ip_set_arn     = ""
# app_waf_ip_set_arn     = ""
# storage_waf_ip_set_arn = ""
# The ALB WAF is attached via ingress.wafAclArn in Helm values (terraform output api_waf_arn).

# ── CloudTrail + Alarms ───────────────────────────────────────────────────────
# Recommended for production compliance. Creates a CloudTrail trail, CloudWatch
# metric filters, 10 security alarms, and an SNS topic.
# enable_cloudtrail_alarms = true
# cloudtrail_alarm_email   = "oncall@example.com"

# ── Helm / LB Controller ALB ──────────────────────────────────────────────────
# The AWS Load Balancer Controller owns the ALB lifecycle entirely.
# After running `helm install` / `helm upgrade`, retrieve the LBC-assigned hostname:
#
#   kubectl get ingress -n medplum medplum \
#     -o jsonpath='{.status.loadBalancer.ingress[0].hostname}'
#
# Set it here and re-run `terraform apply` to update the api_domain Route 53 record.
# Leave empty on the first `terraform apply` (before helm install).
# helm_api_alb_hostname = "k8s-medplum-medplum-XXXXXXXX-XXXXXXXXX.REGION.elb.amazonaws.com"

# ── Bot Lambda ────────────────────────────────────────────────────────────────
# Leave empty to use the role created by this stack (default).
# Override only if you need to reuse a pre-existing bot Lambda execution role.
# bot_lambda_role_arn = ""

# ══ Medplum server config ═════════════════════════════════════════════════════
# The variables below are written to AWS SSM Parameter Store and read by the
# Medplum server at startup. After changing any of these, run:
#   terraform apply && kubectl rollout restart deployment/medplum -n medplum

# ── Authentication ────────────────────────────────────────────────────────────
# reCAPTCHA — both keys required together. The site key (public) is also baked
# into the frontend build via packages/app/.env (RECAPTCHA_SITE_KEY).
# recaptcha_site_key   = "6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# recaptcha_secret_key = "6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Google Sign-In — create OAuth 2.0 credentials at console.cloud.google.com.
# The client ID also goes into packages/app/.env (GOOGLE_CLIENT_ID) for the frontend.
# google_client_id     = "123456789-xxxx.apps.googleusercontent.com"
# google_client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxx"

# ── Registration ──────────────────────────────────────────────────────────────
# register_enabled = true   # set false to disable the /register endpoint in production

# ── Email (AWS SES) ───────────────────────────────────────────────────────────
# Comma-separated list of approved sender addresses for SES.
# Leave empty to allow any verified SES identity.
# approved_sender_emails = "noreply@example.com,support@example.com"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated additional origins beyond appBaseUrl (which is always allowed).
# Only needed if you have custom apps or tools that call the API from a different origin.
# allowed_origins = "https://my-custom-app.example.com,https://storybook.example.com"

# ── Logging & audit ───────────────────────────────────────────────────────────
# log_level         = "INFO"    # NONE | ERROR | WARN | INFO | DEBUG
# save_audit_events = true      # persist AuditEvent resources to the database
# log_audit_events  = true      # stream AuditEvents to CloudWatch
# audit_event_log_group = "/medplum/prod/audit"  # CloudWatch log group name
# redact_audit_events   = true  # strip patient names/PII from stored AuditEvents
